{
  "name": "nodeproj",
  "version": "1.0.0",
  "description": "A hands-on exploration of Node.js core modules and asynchronous programming patterns to understand the V8 runtime environment",
  "keywords": [
    "node",
    "v8",
    "async",
    "event-loop"
  ],
  "homepage": "https://github.com/nadavramon/nodeProj#readme",
  "bugs": {
    "url": "https://github.com/nadavramon/nodeProj/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nadavramon/nodeProj.git"
  },
  "license": "ISC",
  "author": "Nadav Ramon",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --env-file=.env.dev index.js",
    "prod": "node --env-file=.env.prod index.js",
    "test": "vitest run --exclude test/scheduler/test-trigger.test.js",
    "format": "prettier --write \"src/**/*.js\"",
    "test-email": "node --env-file=.env.dev test/scheduler/test-trigger.test.js"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2"
  }
}
